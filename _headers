# =============================================================================
# HTTP security response headers
# =============================================================================
# GitHub Pages CANNOT set custom HTTP response headers, so this file has NO
# effect there. It is provided ready-to-use for hosts that DO honour a
# `_headers` file (Netlify, Cloudflare Pages) or as a reference when placing
# the site behind a reverse proxy / CDN (nginx, Cloudflare Workers, etc.).
#
# The <meta http-equiv="Content-Security-Policy"> tags in the HTML remain the
# only enforcement mechanism on GitHub Pages. Header-only protections such as
# HSTS, X-Frame-Options, and the CSP `frame-ancestors` directive can ONLY be
# enforced through the real headers below.
# =============================================================================

/*
  # Full Content-Security-Policy (identical to the meta tag, plus frame-ancestors
  # which only works as a real header). 'unsafe-inline'/'unsafe-eval' are avoided.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

  # Force HTTPS for 2 years, including subdomains, and allow preload-list submission.
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Clickjacking protection (modern equivalent is CSP frame-ancestors above).
  X-Frame-Options: DENY

  # Block MIME-type sniffing.
  X-Content-Type-Options: nosniff

  # Limit referrer leakage.
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable powerful features the site does not use.
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()

  # Cross-origin isolation hardening.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
